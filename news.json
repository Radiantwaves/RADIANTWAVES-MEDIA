<script>

let mainArticle;
let allArticles=[];

// SAFE FETCH
fetch("news.json?v="+Date.now())
.then(response => response.json())
.then(data => {

mainArticle = data.main;
allArticles = data.news;

// BREAKING
document.getElementById("breakingText").innerHTML =
"Breaking: " + mainArticle.title;

// MAIN STORY
document.getElementById("mainImage").src = mainArticle.image;
document.getElementById("mainTitle").innerText = mainArticle.title;
document.getElementById("mainSummary").innerText = mainArticle.summary;

document.getElementById("readMain").onclick = function(){
openArticle(mainArticle);
};

// SHOW HOME NEWS
displayNews("Home");

// SOCIAL
let socialBox = document.getElementById("social");
socialBox.innerHTML = "";

data.social.forEach(function(s){
let link = document.createElement("a");
link.href = s.link;
link.target = "_blank";

let img = document.createElement("img");
img.src = s.image;

link.appendChild(img);
socialBox.appendChild(link);
});

})
.catch(error => {
console.log("JSON ERROR:", error);
});

// NAVIGATION SAFE
document.querySelectorAll("nav button").forEach(function(btn){
btn.onclick = function(){
let cat = this.getAttribute("data-category");
displayNews(cat);
};
});

// DISPLAY NEWS
function displayNews(category){
let container = document.getElementById("newsSection");
container.innerHTML = "";

let filtered = allArticles.filter(function(item){
return category === "Home" || item.category === category;
});

filtered.forEach(function(item){
let div = document.createElement("div");
div.className = "card";

div.innerHTML =
"<img src='"+item.image+"'>" +
"<h3>"+item.title+"</h3>" +
"<p>"+item.summary+"</p>";

div.onclick = function(){
openArticle(item);
};

container.appendChild(div);
});
}

// OPEN ARTICLE
function openArticle(article){
document.getElementById("main").style.display="none";
document.getElementById("newsSection").style.display="none";
document.getElementById("articlePage").style.display="block";

document.getElementById("articleTitle").innerText=article.title;
document.getElementById("articleImage").src=article.image;
document.getElementById("articleContent").innerText=article.content;
}

// BACK
document.getElementById("backBtn").onclick=function(){
document.getElementById("articlePage").style.display="none";
document.getElementById("main").style.display="block";
document.getElementById("newsSection").style.display="block";
};

// TIME (OUTSIDE FETCH SO IT NEVER BREAKS)
function updateTime(){
let now = new Date();
let timeBox = document.getElementById("liveTime");
if(timeBox){
timeBox.innerHTML =
now.toDateString() + " | " + now.toLocaleTimeString();
}
}
setInterval(updateTime,1000);
updateTime();

// MUSIC
let music = new Audio("news-music.mp3");
music.loop = true;
let musicBtn = document.getElementById("musicBtn");

musicBtn.onclick = function(){
if(music.paused){
music.play();
musicBtn.innerText="⏸ Pause Music";
}else{
music.pause();
musicBtn.innerText="▶ Play Music";
}
};

</script>
